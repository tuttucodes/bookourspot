# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Canonical public URL (no trailing slash). Used for Google OAuth redirectTo — must match
# Supabase Auth → URL Configuration → Redirect URLs exactly.
NEXT_PUBLIC_SITE_URL=https://www.your-domain.com

# Production: set the same vars in Vercel/hosting dashboard.
# Supabase Auth → URL Configuration:
#   Site URL: https://www.your-domain.com (or your canonical domain)
#   Redirect URLs must include:
#     https://www.your-domain.com/auth/callback
#     https://your-domain.com/auth/callback  (if you use apex)
#     http://localhost:3000/auth/callback
# Google Cloud Console → OAuth client → Authorized redirect URIs:
#     https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback

# Supabase server role (required for server tasks)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Twilio WhatsApp notifications
# Sandbox (dev): TWILIO_WHATSAPP_FROM=+14155238886 and recipients must send `join <code>` first.
# Production: requires approved WhatsApp Business sender (Meta review, 1-7 days) plus
# approved Content Template SIDs for sends outside 24h session windows.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=+14155238886
# Optional: approved Twilio Content Template SIDs (prefix HX...). Required to send
# outside the 24h session window.
# TWILIO_CONTENT_SID_OTP=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_CONTENT_SID_BOOKING_CONFIRMED=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_CONTENT_SID_BOOKING_REMINDER=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend email (verify your domain at https://resend.com/domains first)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Bookings <bookings@your-domain.com>
RESEND_REPLY_TO=support@your-domain.com
# Resend webhook signing secret (Resend dashboard -> Webhooks -> reveal Signing Secret, whsec_...)
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel Cron auth (generate with: openssl rand -hex 32)
CRON_SECRET=replace_with_64_hex_chars

# OTP hashing pepper (generate with: openssl rand -hex 32). Rotating invalidates in-flight OTPs.
OTP_PEPPER=replace_with_64_hex_chars

# Supabase DB webhook shared secret (generate with: openssl rand -hex 32).
# Configured in Supabase dashboard -> Database -> Webhooks as a custom
# "Authorization: Bearer <value>" header.
SUPABASE_WEBHOOK_SECRET=replace_with_64_hex_chars
